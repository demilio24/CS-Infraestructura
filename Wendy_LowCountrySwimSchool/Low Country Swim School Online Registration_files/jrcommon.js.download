function chktm(e) {
    var k = document.all ? e.keyCode : e.which;
    if (k == 32 || k == 97 || k == 65 || k == 58 || k == 112 || k == 80 || k == 77 || k == 109) {
        return true;
    }
    return isNumKey(e);
}

