}
//for selClass.
var last_selElemID, last_selUrl;
var selID, win_select;

function selClass(id, Url) {
    var w = screen.width; //640;
    var h = screen.height; //480;
    var winparms = "location=no,scrollbars=yes,resizable=yes,width=" + w + ",height=" + h;
    var snum, f, fldname, f_age, sAge, sBDate, f_gender, sGender;
    var reqdfieldsmsg = "";
    var frm;
    winparms = winparms + ",top=0,left=0";
    selID = id;
    //alert('selClass: id='+id+'\nUrl='+Url);
    var sel = document.getElementById(id);
    if (sel) {
        if (Url == "") {
            Url = document.getElementById("_classurl").value;
        }
        //alert('retID='+sel.name);
        retID = sel.name;
        if (last_selUrl != Url || typeof win_select == "undefined" || win_select.closed) {
            // if window has never been opened, or this is a different popup, open it
            win_select = open(Url, "win_select", winparms);
            if (win_select.opener == null) win_select.opener = self;
            win_select.focus();
            last_selUrl = Url;
        } else {
            // if this window is already open, or already opened and closed.
            try {
                win_select.focus();
            } catch (error) {
                // if the popup had been closed, reopen it
                win_select = open(Url, "win_select", winparms);
                if (win_select.opener == null) win_select.opener = self;
                last_selUrl = Url;
            }
        }
    } else {
        alert("Element ID '" + id + "' not found.");
    }
}

function retClass(retval) {
    //alert('retval='+retval);
    var pairs = retval.split("=");
    var linktext = pairs[2];
    if (pairs[0].substr(0, 4) == "@@lp") {
        //linked page number
        var pattern = /key=[\d]*/i;
        if (pairs[1].indexOf("&") > 0) {
            pairs[1] = pairs[1].substring(0, pairs[1].indexOf("&"));
        }
        try {
            if (document.getElementById(selID)) {
                document.getElementById(selID).value = pairs[1];
            }
        } catch (error) {}
        var link = document.getElementById("link" + selID);
        if (link) {
            //alert(link.tagName+','+link.nodeName);
            if (link.tagName == "INPUT") {
                link.value = linktext;
            } else {
                link.innerHTML = linktext;
            }
        }
        return false;
    }
}

function convertCharacters(obj) {
    var formmatedString = obj.val();

    // � = 8216 convert to ' -- � = 8217 convert to '
    var myRegEx = new RegExp(String.fromCharCode(8216) + "|" + String.fromCharCode(8217), "g");
    formmatedString = formmatedString.replace(myRegEx, "'");

    // � = 8220 convert to " -- � = 8221 convert to "
    var myRegEx = new RegExp(String.fromCharCode(8220) + "|" + String.fromCharCode(8221), "g");
    formmatedString = formmatedString.replace(myRegEx, '"');

    // bullet points from word: 61558, 8226, 61607
    var myRegEx = new RegExp(
        String.fromCharCode(61558) + "|" + String.fromCharCode(8226) + "|" + String.fromCharCode(61607),
        "g"
    );
    formmatedString = formmatedString.replace(myRegEx, String.fromCharCode(111));

    // dash 8211 convert to -
    var myRegEx = new RegExp(String.fromCharCode(8211), "g");
    formmatedString = formmatedString.replace(myRegEx, "-");

    // ... 8230 convert to ...
    var myRegEx = new RegExp(String.fromCharCode(8230), "g");
    formmatedString = formmatedString.replace(myRegEx, "...");

    //trademark symbol 8482 convert to TM
    var myRegEx = new RegExp(String.fromCharCode(8482), "g");
    formmatedString = formmatedString.replace(myRegEx, "TM");

    // copyright symbol 169 convert to (c)
    var myRegEx = new RegExp(String.fromCharCode(169), "g");
    formmatedString = formmatedString.replace(myRegEx, "(c)");

    // registered symbol 174 convert to (r)
    var myRegEx = new RegExp(String.fromCharCode(174), "g");
    formmatedString = formmatedString.replace(myRegEx, "(r)");

    // >> 187 convert to >>
    var myRegEx = new RegExp(String.fromCharCode(187), "g");
    formmatedString = formmatedString.replace(myRegEx, ">>");

    //<< 171 convert to <<
    var myRegEx = new RegExp(String.fromCharCode(171), "g");
    formmatedString = formmatedString.replace(myRegEx, "<<");

    obj.val(formmatedString);
}

// loads classes by location
// parameter dd: the dropdown id of the element where the classes will be loaded.
function loadClasses(dd) {
    $.ajax({
        url: "jr2.0/class/GetSelectListClassesByLocation?locationCode=" + $("#schLocation").val(),
        dataType: "json",
        method: "get",
        success: function (data) {
            var opts = "";
            $.each(data, function (key, val) {
                opts += '<option selected="' + val.Selected + '" value="' + val.Value + '">' + val.Text + "</option>";
            });

            //load dd
            $("#" + dd).html(opts);
        },
        async: false
    });
}

/// Replaces commonly-used Windows 1252 encoded chars that do not exist in ASCII or ISO-8859-1 with ISO-8859-1 cognates.
function replaceWordChars(text) {
    var s = text;

    // smart single quotes and apostrophe
    s = s.replace(/[\u2018|\u2019|\u201A]/g, "'");

    // smart double quotes
    s = s.replace(/[\u201C|\u201D|\u201E]/g, '"');

    // ellipsis
    s = s.replace(/\u2026/g, "...");

    // dashes
    s = s.replace(/[\u2013|\u2014]/g, "-");

    // circumflex
    s = s.replace(/\u02C6/g, "^");

    // open angle bracket
    s = s.replace(/\u2039/g, "<");

    // close angle bracket
    s = s.replace(/\u203A/g, ">");

    // spaces
    s = s.replace(/[\u02DC|\u00A0]/g, " ");

    return s;
}

//This common function allows pages with dynamically added form elements
//to have proper tab indexing when you call it after adding form elements.
//It replaces the need for manually tab indexing in code (and re-indexing everything manually when you add a new field),
//You can also call it on static forms where you are getting weird tab indexing results to fix them.
//Default is filtered to visible input, select(drop list), and textarea elements,
//There are options to add and remove your own additional elements with a jQobect, css selector, html element (see jquery docs on .add and .not).
//Generally you can just pass null for either or nothing for both if you want the default
function setTabIndex(jqAddionalElements, jqExcludeElements) {
    var tabindex = 1;
    var elementsToIndex = jQuery("input,select,textarea").filter(":visible");
    if (jqAddionalElements) elementsToIndex = elementsToIndex.add(jqAddionalElements);
    if (jqExcludeElements) elementsToIndex = elementsToIndex.not(jqExcludeElements);
    elementsToIndex.each(function () {
        jQuery(this).attr("tabindex", tabindex);
        tabindex++;
    });
}

//Auto creates a cc nickname based on ccnum
//Format returned is - "Type Last4Digits"
function createCreditCardNickname(ccnum) {
    //Grab ccnum and get first digit and last 4 digits
    var cardType = "";
    var nickname;
    var last4 = ccnum.substring(ccnum.length - 4);

    cardType = getCreditCardType(ccnum);

    //Create nickname by appending strings
    //In the event we don't set a card type just display the last 4
    nickname = cardType && cardType !== "" ? cardType + " " + last4 : last4;

    return nickname;
}

function getCreditCardType(ccnum) {
    if (!ccnum) {
        return "";
    }

    var first1 = ccnum.substring(0, 1);

    //Determine card type based on first digit
    switch (first1) {
        case "3":
            return "Amex";
        case "4":
            return "Visa";
        case "5":
        case "2":
            return "Mastercard";
        case "6":
        case "8":
            return "Discover";
    }
}

//Gets the true text count without including line breaks, tabs, etc.
function getTextCount(text) {
    return text.replace(/(\r\n|\n|\r|\t)/g, "").length;
}

function limits(obj, limit) {
    var text = jQuery(obj).val();
    var numLineBreaks = (text.match(/\n/g) || []).length;
    var length = text.length;
    if (length > limit - numLineBreaks) {
        jQuery(obj).val(text.substr(0, limit - numLineBreaks));
        var objtitle = jQuery(obj).attr("title");
        if (!objtitle || objtitle.length == 0) {
            alert("Text area can only be " + limit + " characters in length.");
        } else {
            alert(objtitle + " can only be " + limit + " characters in length.");
        }
        //run change on our object.
        jQuery(obj).change();
    }
}

//
// get the months from the decimal value of an age.
// Not perfect and is only reliable used against values saved from JR min/max age drop downs.
//
function getMonthsFromAge(decimalAge) {
    if (!decimalAge || isNaN(decimalAge)) {
        return 0;
    }

    //get remainder (months) from our age
    var remainder = decimalAge - Math.floor(decimalAge);

    //Now do a direct conversion (out of 12) to see what month this is
    var months = remainder * 12;

    //We only want WHOLE months (don't care about partials)
    //  so decide if we round down or up

    //If we're .05 or closer to the ceiling then we should round up.
    //This is caused by losing decimal places when converting to decimal from UI.
    if (Math.ceil(months) - months <= 0.05) {
        return Math.ceil(months);
    }

    //in most cases we just round down to the closest completed month
    return Math.floor(months);
}

//Get differnce in months between two dates.
//This is not relative to the entire time span but only one year.
//This function is intended to be used in conjuction with dateDiffYears when validating ages.
function dateDiffMonths(fromDate, toDate) {
    //Get individual month/day from both dates.
    var fromMonths = fromDate.getMonth() + 1;
    var toMonths = toDate.getMonth() + 1;
    var fromDays = fromDate.getDate();
    var toDays = toDate.getDate();

    //Now do a basic difference via subtraction
    var monthsDiff = toMonths - fromMonths;

    //reduce months by 1 if to date isn't really a month ahead
    if (toDays < fromDays) {
        monthsDiff--;
    }

    //Now if we're negative then add 12 to offset
    if (monthsDiff < 0) {
        monthsDiff += 12;
    }

    return monthsDiff;
}

function dateDiffYears(fromDate, toDate) {
    //Get individual month/day from both dates.
    var fromMonths = fromDate.getMonth() + 1;
    var toMonths = toDate.getMonth() + 1;
    var fromDays = fromDate.getDate();
    var toDays = toDate.getDate();

    var yearsDiff = toDate.getYear() - fromDate.getYear();

    //reduce if we haven't actually passed a year based on months
    if (toMonths < fromMonths) {
        yearsDiff--;
    } else if (toMonths === fromMonths) {
        //else if months are equal we need to test days to see if the last year is a full one
        if (toDays < fromDays) {
            yearsDiff--;
        }
    }

    return yearsDiff;
}

/**
 * Opens the Discontinued Browser Modal for IE (all versions). This is for customers - a different modal exists for internal users.
 * Returns a promise that only resolves. If not IE, promise resolves immediately - so no if-statements are needed outside of this function.
 **/
function _openDiscontinuedBrowserModalIfIE_ASP() {
    var discontinuedBrowserModalUrl = "/jr3.0/Login/DiscontinuedBrowserForCustomersModal";
    var d = jQuery.Deferred();

    // Open the IE modal, if IE
    /*
     * DEV NOTE - this code is copy-pasted into other areas (we need it for Parent Portal, for example)
     * Find all instances using comment FLAG_BROWSER_IE_CHECK
     */
    // MSIE = IE10 and below, Trident = IE11
    var ua = navigator.userAgent;
    var isIE = ua.indexOf("MSIE ") > -1 || ua.indexOf("Trident/") > -1;
    if (!isIE) {
        // Get out, no modal needed.
        return d.resolve().promise();
    }

    jQuery.ajax({
        type: "GET",
        url: discontinuedBrowserModalUrl,
        dataType: "html",
        success: function (resp) {
            // Wrap the response in the necessary modal elements (CUSTOM for this ticket)
            var modalContent = jQuery(document.createElement("div")).addClass("asp-no-browser-cust-mdl-content p-15");
            var modalDialog = jQuery(document.createElement("div")).addClass("asp-no-browser-cust-mdl-dialog");
            var modalFade = jQuery(document.createElement("div")).addClass("asp-no-browser-cust-mdl-fade");
            modalContent.html(resp);
            modalDialog.append(modalContent);
            modalFade.append(modalDialog);

            jQuery(document.body).prepend(modalFade);

            modalFade.show();

            // Close on click
            modalFade.find("button").on("click", function () {
                modalFade.remove();
                d.resolve();
            });
        },
        error: function (data) {
            // On error, don't continue.
            console.error("Could not load Discontinued Browser Modal.");
            d.resolve();
        }
    });

    return d.promise();
}
