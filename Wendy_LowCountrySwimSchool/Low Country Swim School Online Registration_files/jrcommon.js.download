/*  jackrabbit formdiv code pulled out of javascript.js */
var loadform_srcel;

function jLoadform(formurl, oldurl, topOverlay) {
    //arg4=use existing elem, arg5=optional diff target
    //alert('jloadform called...'+arguments.length);
    var formdiv,
        formdivid = "",
        targetid = "",
        target;
    if (arguments.length >= 4 && arguments[3] != "") {
        formdivid = arguments[3];
        if (formdivid.substring(0, 1) != "#") {
            formdivid = "#" + formdivid;
        }
        formdiv = jQuery(formdivid);
    } else {
        formdivid = "#formdiv";
    }
    if (arguments.length >= 5 && arguments[4] != "") {
        targetid = arguments[4];
        if (targetid.substring(0, 1) != "#") {
            targetid = "#" + targetid;
        }
        target = jQuery(targetid);
    } else {
        targetid = formdivid;
    }

    if (document.getElementById(formdivid) == null || typeof jQuery("#" + formdivid) == "undefined") {
        createFormdiv();
    }
    if (arguments.length > 1) {
        try {
            loadform_srcel = window.event && window.event.srcElement ? window.event.srcElement : target_obj;
        } catch (e) {}
    }
    //alert('loadform:srcelem.tagName='+loadform_srcel.tagName);
    if (jQuery("#spin") && jQuery("#spin").length) {
        jQuery("#spin")[0].style.visibility = "";
    }

    var ms = 0,
        state = 0;
    then = new Date();
    then.setTime(then.getTime() - ms);
    //alert(updateelem);
    var frmpkg = "",
        updateelem = formdivid; //'linkedtrans.asp?id='+$('tID').value+'&ajaxrnd='+ (Math.random() * Date.parse(new Date())) ;
    if (formurl != "") {
        if (formurl.length > 2000) {
            //to handle large URL strings, switch to post form-data.
            //alert('url length='+formurl.length);
            var parts = formurl.split("?");
            formurl = parts[0];
            frmpkg = parts[1];
            //alert(frmpkg);
        }

        jQuery.ajax({
            type: "POST",
            url: formurl,
            data: frmpkg, //"name=John&location=Boston",
            success: function (data) {
                jQuery(targetid).empty();

                //alert( "Response: " + data );
                if (data == "revalidate" || data.indexOf("re-validate session") > -1) {
                    document.location.reload();
                } else {
                    try {
                        if (AlterAllSelects) AlterAllSelects("hidden");
                    } catch (e) {}
                    jQuery(targetid).html(data);
                    jcenterdiv(jQuery(targetid), 1);
                    jQuery(targetid).show();
                    if (jQuery("#divMessage")) {
                        jQuery("#divMessage").empty();
                    }

                    jQuery(window).on("resize", function () {
                        if (formdiv) {
                            if (formdiv.is(":visible")) {
                                jcenterdiv(formdiv, topOverlay);
                            }
                        }
                    });
                }
            },
            error: function (data) {
                alert("jLoadform Error loading form.  Response: " + data);
            }
        });
    } else {
        if (formdiv) {
            //overlay(topOverlay);
            jcenterdiv(formdiv, topOverlay);
            formdiv.fadeIn("slow");
        } else {
            alert("form not found");
        }
    }
    return false;
}

function jcenterdiv(id) {
    if (arguments.length > 1 && arguments[1] != "") {
        var topOvr = arguments[1];
        overlay(topOvr);
    }
    //alert(typeof id);
    var d = typeof id == "object" ? jQuery(id) : jQuery("#" + id);
    if (d) {
        var dw = parseInt(d.css("width"));
        var dh = parseInt(d.css("height"));
        if (isNaN(dw)) dw = 0;
        if (isNaN(dh)) dh = 0;
        var winh = getWindowHeight(),
            winw = getWindowWidth();
        var t = "" + (winh / 2 - dh / 2) + "px";
        var l = "" + (winw / 2 - dw / 2) + "px";
        //alert('winh='+winh+' dh='+dh+' getY='+getY());
        //if(typeof getY!='undefined') { var y=getY(); var newt=((y+(winh/3))-(dh/2)); if(newt<y){newt=y;}t=''+newt+'px'; }
        if (typeof getY != "undefined") {
            var y = getY();
            var newt = y + winh / 2 - dh / 2;
            if (newt < y) {
                newt = y;
            }
            t = "" + newt + "px";
        }
        //alert('winh='+winh+' dh='+dh+' getY='+getY()+' t='+t);
        d.css({ top: t, left: l });
    }
}
function overlay(topOverride) {
    var d = document;
    var winh = getWindowHeight(),
        winw = getWindowWidth();
    //alert(document.body.offsetWidth+','+document.body.scrollWidth+','+document.documentElement.clientWidth+','+document.body.clientWidth+','+document.body.scrollLeft);
    var ovr = document.getElementById("overlay");
    if (ovr) {
        if (document.body.scrollLeft) {
            ovr.style.left = "" + document.body.scrollLeft + "px";
        }
        if (document.getElementById("ovrimg")) document.getElementById("ovrimg").style.width = winw + "px";
        document.getElementById("overlay").style.display = "";
    } else {
        var objBody = document.getElementsByTagName("body").item(0);
        var ovr = document.createElement("div");
        //ovr.setAttribute('id ,'overlay');
        ovr.id = "overlay";
        ovr.style.position = "absolute";
        ovr.style.zIndex = "90";
        //ovr.className='overlay';
        //alert(winh+','+d.body.clientHeight+','+d.body.scrollHeight);
        if (d.body.clientHeight && d.body.clientHeight > winh) winh = d.body.clientHeight;
        if (d.body.scrollHeight && d.body.scrollHeight > winh) winh = d.body.scrollHeight;
        winh = winh + 400; //stretch out the overlay to cover the page even if you maximiz the page on a large monitor
        winw = winw + 400;
        if (typeof topOverride == "undefined" || !topOverride || topOverride.length == 0) {
            ovr.style.top = "0px"; //LSP - discussed with Mike.  Setting to top of form.
            //winh = winh-100;
        } else {
            ovr.style.top = topOverride + "px";
            winh = winh + 20;
        }
        ovr.style.left = "2px";
        //ovr.style.opacity='.5';
        ovr.style.display = "";
        ovr.innerHTML =
            '<span style="position:absolute;filter:alpha(opacity=40);-moz-opacity:.4;opacity:.4;"><img id="ovrimg" src="../images/overlay.gif" width="' +
            winw +
            '" height="' +
            winh +
            '"></span>';
        objBody.insertBefore(ovr, objBody.firstChild);
    }
    document.body.style.overflow = "hidden";
}

function hideoverlay() {
    //alert('hideoverlay');
    var ovrl = document.getElementById("overlay");
    if (ovrl) ovrl.style.display = "none";
    try {
        if (AlterAllSelects) AlterAllSelects("");
    } catch (e) {}
    document.body.style.overflow = "";

    //This removes the container div, to prevent the recreation of the from on each jLoadForm call.
    destoryFormDiv();
}

//When displaying forms from our 'Form Editor' or 'Popup Editor'
//We may need to save 'tags' in place of symbols or characters because they get stripped or converted to something else on save.
//Example + gets turned into a space, so to display a '+' save the tag as [plus]
function convertFormTagsForDisplay(formText) {
    //do pluses
    formText = formText.replace(/(\[plus])/g, "+");

    return formText;
}

function createFormdiv() {
    var objBody = document.getElementsByTagName("body").item(0);
    var fdiv = document.createElement("div");
    var s = fdiv.style;
    fdiv.setAttribute("id", "formdiv");
    s.width = "400px";
    s.height = "200px";
    var winh = getWindowHeight();
    var winw = getWindowWidth();
    s.top = "" + (winh / 2 - 100) + "px";
    s.left = "" + (winw / 2 - 400 / 2) + "px";
    s.display = "none";
    fdiv.className = "asp-modal-div";
    fdiv.innerHTML = "Loading...";
    objBody.insertBefore(fdiv, objBody.firstChild);
}

function destoryFormDiv() {
    var f = jQuery("#formdiv");
    if (f.length > 0) f.remove();
}

function getWindowHeight() {
    var winH = 0;
    if (typeof window.innerHeight == "number") {
        winH = window.innerHeight;
    } else {
        if (document.documentElement && document.documentElement.clientHeight) {
            winH = document.documentElement.clientHeight;
        } else {
            if (document.body && document.body.clientHeight) {
                winH = document.body.clientHeight;
            }
        }
    }
    return winH;
}
function getWindowWidth() {
    var winW = 0;
    if (typeof window.innerWidth == "number") {
        winW = window.innerWidth;
    } else {
        if (document.documentElement && document.documentElement.clientWidth) {
            winW = document.documentElement.clientWidth;
        } else {
            if (document.body && document.body.clientWidth) {
                winW = document.body.clientWidth;
            }
        }
    }
    return winW;
}
function getY() {
    if (self.pageYOffset) {
        return self.pageYOffset;
    } else if (document.documentElement && document.documentElement.scrollTop) {
        return document.documentElement.scrollTop;
    } else if (document.body) {
        return document.body.scrollTop;
    }
}

function setCookie(name, value, expires, path, domain, secure) {
    var curCookie =
        name +
        "=" +
        escape(value) +
        (expires ? "; expires=" + expires.toGMTString() : "") +
        (path ? "; path=" + path : "") +
        (domain ? "; domain=" + domain : "") +
        (secure ? "; secure" : "");
    document.cookie = curCookie;
}

function isValidKey(e, fmt) {
    var k = document.all ? e.keyCode : e.which;
    if (fmt == "num")
        return (k > 47 && k < 58) || k == 8 || k == 0 || k == null || k == 9 || k == 13 || k == 27 || k == 118;
    else if (fmt == "dec")
        return (k > 47 && k < 58) || k == 8 || k == 0 || k == 46 || k == 44 || k == 45; //46=. 44=, 45=-
    else if (fmt == "date")
        return (
            (k > 47 && k < 58) ||
            k == 8 ||
            k == 0 ||
            k == null ||
            k == 0 ||
            k == 8 ||
            k == 9 ||
            k == 13 ||
            k == 27 ||
            k == 47 ||
            k == 45
        ); //47=/  45=-
    else if (fmt == "time")
        //0-9, :, [am,pm]
        return (
            (k > 47 && k < 59) ||
            k == 112 ||
            k == 109 ||
            k == 97 ||
            k == 65 ||
            k == 80 ||
            k == 77 ||
            k == 8 ||
            k == 0 ||
            k == 32
        );
    else if (fmt == "pos") return (k > 47 && k < 58) || k == 8 || k == 0 || k == 46 || k == 44; //46=. 44=, 45=-
    else if (fmt == "posint") return (k > 47 && k < 58) || k == 8 || k == 0; //no commas, no decimals, no hyphens.
    //decimal
    else return (k > 47 && k < 58) || k == 8 || k == 0 || k == 46 || k == 44; //46=.  44=,
}
function isNumKey(e) {
    return isValidKey(e, "num");
}
function isDecKey(e) {
    return isValidKey(e, "dec");
}
function isPosNumKey(e) {
    return isValidKey(e, "pos");
}
function isPosIntKey(e) {
    return isValidKey(e, "posint");
}
function isDateKey(e) {
    return isValidKey(e, "date");
}
function isTimeKey(e) {
    return isValidKey(e, "time");
}
function validDate(el) {
    if (el && el.value == "") return true;
    var result = parseDate(el.value);
    //alert(el.value+' '+result+' '+(result==null));
    if (result == null) {
        alert("Invalid date: " + el.value);
        try {
            el.focus();
        } catch (e) {}
        return false;
    }
    return true;
}

//Valid time format 1:00 PM/AM or 1:00AM/PM
function validTime(postAlert) {
    var $el = jQuery(this);
    if ($el.val() === "") return true;

    var val = jQuery.trim($el.val());

    var validTime = val.match(/^(0?[1-9]|1[012])(:[0-5]\d)([ ]?)[APap][mM]$/);
    if (!validTime) {
        $el.addClass("error");

        if (postAlert) alert("Invalid time format. Please format as 1:00PM");
    } else {
        $el.removeClass("error");
    }
    return validTime;
}

function futureYear(el, yrlimit) {
    // don't let dates be more than 10 yrs in the future
    var result = parseDate(el.value);
    var d = new Date();
    var futureYr = d.getFullYear() + yrlimit;
    var strfutureDate = d.getMonth() + 1 + "/" + d.getDate() + "/" + futureYr;
    var futureDate = new Date(strfutureDate);
    if (result > futureDate) {
        alert("Pay Periods can't be created more than " + yrlimit + " years into the future: " + el.value);
        try {
            el.focus();
        } catch (e) {}
        return false;
    }
    return true;
}

function showhideTabs(id) {
    //var moz = (typeof document.implementation != 'undefined') && (typeof document.implementation.createDocument != 'undefined');
    //Change TabRow properties
    //var divTabRow = document.getElementById('divTabRow');
    //var tabs = divTabRow.getElementsByTagName('TD');

    var tabs = $.makeArray($("TD.tab"));
    for (var i = 0; i < tabs.length; i++) {
        var tab = tabs[i];
        if (tab.id == "divTab" + id) {
            //The Selected Tab.
            tab.style.backgroundColor = "#F0D49D";
            if (i == 0) tab.style.borderLeft = ""; //first tab?
            // tab.style.borderBottom='';
            tab.style.borderBottom = "2px solid #F0D49D";
            //Set cookie for active tab on page
            var expdate = new Date();
            expdate.setTime(expdate.getTime() + 20 * 24 * 60 * 60 * 1000);
            setCookie("currpagetab", id, expdate);
        } else {
            tab.style.backgroundColor = "#E0E0E0";
            tab.style.borderBottom = "1px solid buttonhighlight";
            if (i == 0) tab.style.borderLeft = "1px solid buttonhighlight";
        }
    }
    //Change divTabBody properties
    //var divTabBodies = document.getElementById('divTabBodies');
    //var tabdivs = divTabBodies.getElementsByTagName('div');
    var tabdivs = $.makeArray($("#divTabBodies > .divTab"));
    for (var i = 0; i < tabdivs.length; i++) {
        var tab = tabdivs[i];
        if (tab.id == "divTabBody" + id) {
            tab.style.display = "block";
            tab.style.backgroundColor = "F0D49D";
        } else {
            //if (tab.id.substring(0,10)=='divTabBody') {
            tab.style.display = "none";
            //}
        }
    }
}

function setchg(evt) {
    var src;
    if (window.event) {
        //alert('IE '+evt.srcElement.tagName);
        evt = window.event;
        if (evt && evt.srcElement) src = evt.srcElement;
    } else {
        //alert('non-IE '+evt.target.tagName);
        if (evt && evt.target) src = evt.target;
    }
    if (src) {
        jQuery(src).addClass("chg");
    }
}

function print(e) {
    //alert('print');
    if (arguments.length > 1) {
        //print the contents of the element id passed in as argument[1]
        tbl = document.getElementById(arguments[1]);
        rpttitle = arguments.length > 2 ? arguments[2] : ""; //optional title for printed element
    } else {
        var el,
            div,
            tbl,
            rpttitle = "";
        el = e.target || e.srcElement;
        if (el && el.parentNode) {
            //alert(el.parentNode.tagName);
            var div = el.parentNode;
            var divID = div.id;
            //alert(div.tagName+','+divID+','+$(el.parentNode).attr('rpttitle'));
            if (div && div.getAttribute("rpttitle")) {
                rpttitle = div.getAttribute("rpttitle");
            }
            //alert($('#'+divID+' select')[0]);
            if (divID.length > 0) {
                tbl = $("#" + divID + " table")[0];
            } else {
                tbl = $("table", div)[0];
            }
            if (!tbl) {
                tbl = div.nextSibling;
                while (tbl.nodeType != 1 && tbl.tagName != "TABLE") {
                    tbl = tbl.nextSibling;
                }
            }
        }
    }
    if (tbl) {
        var win1 = window.open("", "print");
        win1.document.open();
        win1.document.write("<html><head><title>" + rpttitle + " - Print</title>");
        win1.document.write(
            '<link rel="stylesheet" href="http://fonts.googleapis.com/css?family=Lato:400,700,900,400italic,700italic" type="text/css" />'
        );
        win1.document.write('<link rel="stylesheet" href="' + jr_css_path + '" type="text/css"/>');
        win1.document.write(
            '<style type="text/css">#tblR TD {vertical-align:top} textarea {height:100%; width:100%; overflow:hidden} </style>'
        );
        win1.document.write("</head>");
        win1.document.write("<body><h2>" + rpttitle + "</h2>");
        win1.document.write(
            '<input type="button" class="noprint" value="Close" onclick="window.close();"/>&nbsp; &nbsp; &nbsp; <input type="button" class="noprint" value="Print" onclick="window.print();return false;"/>'
        );
        win1.document.write("<br>");
        win1.document.write("<br>");
        win1.document.write(
            '<table id="tblR" class="tablesorter" border="0" cellpadding="0" cellspacing="1" width="100%">'
        );
        win1.document.write(tbl.innerHTML);
        win1.document.write("</body>");
        win1.document.write("</html>");
        win1.document.close();

        tbl = null;
        try {
            win1.focus();
        } catch (e) {}
        //in chrome the print preview window is empty so don't open the preview window and allow the user to print using the print button
        var isChrome = !!window.chrome && !!window.chrome.webstore;
        if (window.print && !isChrome) {
            win1.print();
        }
        win1 = null;
    }
    return false;
}

function jPostFormFromRecitalListAdd(frmid, url, targetid, frmpkg, redirect_url, successCallback) {
    //arg2=optional url, arg3=optional targetid, arg4=optional frmpkg, arg5=redirect_url, arg5=successCallback

    url = url || "";
    targetid = targetid || "";
    frmpkg = frmpkg || "";
    redirect_url = redirect_url || "";
    successCallback = successCallback || "";

    var f = jQuery("#frm" + frmid);
    if (f) {
        //alert(arguments.length);
        if (arguments.length >= 2 && arguments[1] != "") {
            url = arguments[1];
        }
        if (arguments.length >= 3 && arguments[2] != "") {
            targetid = arguments[2];
            if (targetid.substring(0, 1) != "#") {
                targetid = "#" + targetid;
            }
        }
        if (arguments.length >= 4 && arguments[3] != "") {
            frmpkg = arguments[3];
        }
        if (arguments.length >= 5) {
            redirect_url = arguments[4];
        }
        //var frmpkg = f.serialize();

        if (frmpkg == "") {
            var frmpkg = jQuery("#frm" + frmid + " .chg").serialize(); //serialize only changed fields

            //alert(frmpkg);
            //return false;
            //pickup changed checkboxes that are unchecked
            var frm_els = jQuery("#frm" + frmid + ' input[type="checkbox"]');
            var chkpkg = "",
                elnum = frm_els.length;
            for (var i = 0; i < elnum; ++i) {
                if (frm_els[i].checked == false) {
                    if (chkpkg != "") chkpkg = chkpkg + "&";
                    chkpkg = chkpkg + frm_els[i].id + "=0";
                }
            }
            if (chkpkg.length > 0) {
                if (frmpkg.length > 0) frmpkg += "&";
                frmpkg += chkpkg;
            }
        }

        frmopts = jQuery("#frmopts", f).val();
        //alert('jPostForm frmpkg: '+frmpkg);
        if (targetid == "") {
            targetid = "#div" + frmid + "_Response";
        }
        jQuery(targetid).show();
        if (url == "") {
            url = jQuery("#posturl", f).val();
            if (url == "") {
                var pathArray = document.location.pathname.split("/");
                var pagename = pathArray[pathArray.length - 1];
                url = pagename + "?action=run"; //assume current page
            }
            if (url == "") return false;
        }
        //alert('jPostForm url='+url+'\n'+frmpkg);
        jQuery(targetid).empty();
        return jQuery.ajax({
            type: "POST",
            url: url,
            data: frmpkg, //"name=John&location=Boston",
            success: function (data) {
                if (frmopts && frmopts.indexOf("debug") > -1) {
                    alert(data);
                }
                if (data.indexOf("<scr" + "ipt" + ">") > -1) {
                    var msg = data.substring(0, data.indexOf("<scr" + "ipt>"));
                } else {
                    var msg = data;
                    if (msg.indexOf("Error in") > -1) {
                        alert("There was a problem:\n" + msg);
                    }
                }
                if (msg.length > 0) alert(msg);
                jQuery(targetid).append(data);

                //If output msg has error dont' close window.
                if (data.indexOf("ERROR:") > -1) {
                    $("#idSubmit").removeAttr("disabled");
                    return false;
                }

                //$('#divMessage').html(msg).show();
                hideoverlay();

                jQuery("#div" + frmid).hide();
                jQuery("#formdiv").hide();
                if (redirect_url != "") {
                    document.location.href = redirect_url;
                }
                //if(data.indexOf('added')>-1) {search()}
                //$('#divMessage').hide().empty();

                if (typeof successCallback === "function") {
                    successCallback();
                }
            },
            error: function (data) {
                var r = data.responseText;
                if (r.indexOf("page cannot be found") > -1) {
                    alert("Page cannot be found in url: " + url);
                } else {
                    alert("jPostForm Error. Response: " + r);
                }
            }
        });
    } else {
        alert("form not found");
    }
}
function jPostForm(frmid, url, targetid, frmpkg, redirect_url, successCallback) {
    //arg2=optional url, arg3=optional targetid, arg4=optional frmpkg, arg5=redirect_url, arg5=successCallback

    url = url || "";
    targetid = targetid || "";
    frmpkg = frmpkg || "";
    redirect_url = redirect_url || "";
    successCallback = successCallback || "";

    var f = jQuery("#frm" + frmid);
    if (f) {
        //alert(arguments.length);
        if (arguments.length >= 2 && arguments[1] != "") {
            url = arguments[1];
        }
        if (arguments.length >= 3 && arguments[2] != "") {
            targetid = arguments[2];
            if (targetid.substring(0, 1) != "#") {
                targetid = "#" + targetid;
            }
        }
        if (arguments.length >= 4 && arguments[3] != "") {
            frmpkg = arguments[3];
        }
        if (arguments.length >= 5) {
            redirect_url = arguments[4];
        }
        //var frmpkg = f.serialize();

        if (frmpkg == "") {
            var frmpkg = jQuery("#frm" + frmid + " .chg").serialize(); //serialize only changed fields

            //alert(frmpkg);
            //return false;
            //pickup changed checkboxes that are unchecked
            var frm_els = jQuery("#frm" + frmid + ' input[type="checkbox"]');
            var chkpkg = "",
                elnum = frm_els.length;
            for (var i = 0; i < elnum; ++i) {
                if (frm_els[i].checked == false) {
                    if (chkpkg != "") chkpkg = chkpkg + "&";
                    chkpkg = chkpkg + frm_els[i].id + "=0";
                }
            }
            if (chkpkg.length > 0) {
                if (frmpkg.length > 0) frmpkg += "&";
                frmpkg += chkpkg;
            }
        }

        frmopts = jQuery("#frmopts", f).val();
        //alert('jPostForm frmpkg: '+frmpkg);
        if (targetid == "") {
            targetid = "#div" + frmid + "_Response";
        }
        jQuery(targetid).show();
        if (url == "") {
            url = jQuery("#posturl", f).val();
            if (url == "") {
                var pathArray = document.location.pathname.split("/");
                var pagename = pathArray[pathArray.length - 1];
                url = pagename + "?action=run"; //assume current page
            }
            if (url == "") return false;
        }
        //alert('jPostForm url='+url+'\n'+frmpkg);
        jQuery(targetid).empty();
        return jQuery.ajax({
            type: "POST",
            url: url,
            data: frmpkg, //"name=John&location=Boston",
            success: function (data) {
                if (frmopts && frmopts.indexOf("debug") > -1) {
                    alert(data);
                }
                if (data.indexOf("<scr" + "ipt" + ">") > -1) {
                    var msg = data.substring(0, data.indexOf("<scr" + "ipt>"));
                } else {
                    var msg = data;
                    if (msg.indexOf("Error in") > -1) {
                        alert("There was a problem:\n" + msg);
                    }
                }
                if (msg.length > 0) alert(msg);
                jQuery(targetid).append(data);

                //If output msg has error dont' close window.
                if (data.indexOf("ERROR:") > -1) {
                    $("#idSubmit").removeAttr("disabled");
                    return false;
                }

                //$('#divMessage').html(msg).show();
                hideoverlay();

                //After the post has come back successful, let's remove the form from the DOM
                //so we don't collide with any subsequent posts from the same calling page. -Tim 11/2/2011
                f.remove();

                jQuery("#div" + frmid).hide();
                jQuery("#formdiv").hide();
                if (redirect_url != "") {
                    document.location.href = redirect_url;
                }
                //if(data.indexOf('added')>-1) {search()}
                //$('#divMessage').hide().empty();

                if (typeof successCallback === "function") {
                    successCallback();
                }
            },
            error: function (data) {
                var r = data.responseText;
                if (r.indexOf("page cannot be found") > -1) {
                    alert("Page cannot be found in url: " + url);
                } else {
                    alert("jPostForm Error. Response: " + r);
                }
            }
        });
    } else {
        alert("form not found");
    }
}
function jPostFormWithRedirect(frmid, url) {
