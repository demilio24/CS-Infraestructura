// *************************************************************
//General funcs
function formatCurrency(num,withcents) {
	num = num.toString().replace(/\$|\,/g,'');
	if(isNaN(num))
		num = "0";
	sign = (num == (num = Math.abs(num)));
	num = Math.floor(num*100+0.50000000001);
	cents = num%100;
	num = Math.floor(num/100).toString();
	if(cents<10)
		cents = "0" + cents;
	for (var i = 0; i < Math.floor((num.length-(1+i))/3); i++)
	num = num.substring(0,num.length-(4*i+3))+','+
	num.substring(num.length-(4*i+3));
	if (withcents)
		return (((sign)?'':'-') + '' + num + '.' + cents);
	else
		return (((sign)?'':'-') + '' + num);
}

function checkAge(el)
{
	var elid = el.id;
	var bdate = el.value;
	var m,d,y;
	var curyear = new Date().getFullYear();
	var bUkDt;

	//alert('curyear='+curyear+',bdate='+bdate);
	el.setAttribute("Age","");
	
	if (bdate.indexOf('/')>0) parts = bdate.split('/');
	if (bdate.indexOf('-')>0) parts = bdate.split('-');
	if (bdate.length>=6 && parts.length==3) {

		if (document.getElementById('bUkDate')) 
			bUkDt = document.getElementById('bUkDate').value;
		else
			bUKDt = 0;

		if (bUkDt == 1) {
			m=parts[1];
			d=parts[0];
			y=parts[2];
			if (bdate.indexOf('-')>0)  el.value=d+'/'+m+'/'+y;
		}
		else {
			m=parts[0];
			d=parts[1];
			y=parts[2];
			if (bdate.indexOf('-')>0)  el.value=m+'/'+d+'/'+y;
		}
		if (y.length==1) y='200'+y;
		if (y.length==2) {
			if (y<20) 
				y = '20'+y.toString();
			else
				y = '19'+y.toString();
		}
	}
	
	//alert(m+'/'+d+'/'+y);
	//document.getElementById('S1Age').innerHTML='<br/>Age: '+age;
	var snum = elid.substring(0,2);
	var elage = document.getElementById(snum+'Age');
	if (elage) {
		if (y>0 && m>0 && d>0) {
			age=calcage(y,m,d);
			//alert('calcage='+age);
			if (age.indexOf('yrs')>0) {
				var curage_y = age.substring(0,age.indexOf('yrs')-1)
				//alert('setting elemID '+elid+' attribute Age='+curage_y);
				el.setAttribute("Age",curage_y);
			}
			elage.innerHTML='<br/>Current Age: '+age;
			
			if (snum=='S1')	//check student 1 preloaded class reqs.
			{
				if(document.getElementById('S1C1'))
				{
					var s1c1=document.getElementById('S1C1').value;
					//alert('checkAge: S1C1='+s1c1);
					if(s1c1!=''&&s1c1!='0') {
						var cminAge = parseInt(document.getElementById('preLoadClassMinAge').value);
						cminAge=(isNaN(cminAge))?'':parseInt(cminAge);
						var cmaxAge = parseInt(document.getElementById('preLoadClassMaxAge').value);
						cmaxAge=(isNaN(cmaxAge))?'':parseInt(cmaxAge);
						//alert('Class minage='+cminAge+',curage_y='+curage_y+',parseInt(cminAge)='+parseInt(cminAge)+',parseInt(curage_y)='+parseInt(curage_y));

						var now = new Date();
						var nowm=(now.getMonth()+1), nowd=now.getDate(), nowy=now.getFullYear();
						//alert('now='+now+',nowm='+nowm+',nowd='+nowd+',nowy='+parseInt(nowy));
						//next bday
						if (m>nowm||(m==nowm&&d>nowd)) 	// has birthday has already passed this year?
							var nextbday = new Date(m+"/"+d+"/"+nowy);
						else
							var nextbday = new Date(m+"/"+d+"/"+(nowy+1));
						//alert('next bday='+nextbday);
						var cStartDt = document.getElementById('preLoadClassStartDate').value;
						var dStartDt = new Date(cStartDt);
						if (isNaN(dStartDt)) dStartDt=0;
						var cEndDt = document.getElementById('preLoadClassEndDate').value;
						var dEndDt = new Date(cEndDt);
						if (isNaN(dEndDt))  dEndDt=0;
						//alert('StartDt='+cStartDt+',EndDt='+cEndDt+',dStart='+dStartDt+',dEnd='+dEndDt);
						var s_age=parseInt(curage_y);
						//alert('age='+s_age);
						var bMinAge=false, bMaxAge=false;
						if ((cminAge==''||(cminAge<=s_age && (cStartDt==''||dStartDt<=nextbday)) )||(dStartDt>=nextbday&&cminAge<=(s_age+1)))
						{	//alert('MinAge is good.');
							bMinAge=true;
						} //else { alert('MinAge is NOT good.'); }
						if ((cmaxAge==''||(cmaxAge>=s_age && (cStartDt==''||dStartDt<=nextbday) ))||(dStartDt>nextbday&&cmaxAge>=(s_age+1)))
						{	//alert('MaxAge is good.');
							bMaxAge=true;
						} //else { alert('MaxAge is NOT good.'); }

			            f_age = document.getElementById('_AgeFilter');
                        var bCheckAge = false;
                        if (f_age && f_age.value == 'Y')
                            bCheckAge = true;

                            
						if ((bMinAge&&bMaxAge) || !bCheckAge) {
							return true;
						} else {
							var link = document.getElementById('linkS1C1');
							if (link) {className=' "'+link.innerText+'"';}
							return false;
						}
						//checkClass();
					}
				}
				return true;
			}
		} else {
		elage.innerHTML='';
		}
	}
}

