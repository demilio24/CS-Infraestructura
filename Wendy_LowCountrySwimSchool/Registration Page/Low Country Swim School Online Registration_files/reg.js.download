function checkClass()
{
	//alert('checkClass');
	var af=document.getElementById('_AgeFilter').value;
	var gf=document.getElementById('_GenderFilter').value;
	var s1c1=document.getElementById('S1C1').value;
	var bdate=document.getElementById('S1BDate');
	var gndr=document.getElementById('S1Gender');
	var gndrval=gndr.options[gndr.selectedIndex].text;	
	if(gndrval!='') gndrval=gndrval.substring(0,1);
	if(s1c1!=''&&s1c1!='0'&&bdate.value!=''&&(af=='Y'||gf=='Y')) {
		var curage_y=bdate.getAttribute("Age");
		//alert('Age='+curage_y+',Gender='+gndrval);
		var url='webreg_checkclass.asp?cid='+s1c1+''; // &s_age='+curage_y+'&s_bdate='+bdate.value+'&s_gndr=F'
		if(af=='Y') url+='&s_age='+curage_y+'&s_bdate='+bdate.value;
		if(gf=='Y'&&gndrval!='') url+='&s_gndr='+gndrval;
		url+='&rnd='+ (Math.random() * Date.parse(new Date())) 
		
		alert('checkClass: url='+url);
		//var url = 'webreg_checkclass.asp';
		var hdrs = ['HTTP_xml','on'];		
		var pars = 'cid='+s1c1+'&s_age='+'&s_bdate='+bdate+'&s_gndr='+gndrval+'&rnd='+ (Math.random() * Date.parse(new Date())) ;
		//alert('checkClass: pars='+url);
		jQuery.ajax({
			type: 'get',
			url: url,
			Headers: hdrs,
			complete: function(resp) {
				if (resp.responseText.indexOf('Not OK') > -1) {
					alert('Student #1 first class selected does not match Student Age');
					return false;
				} else {
					return true;
				}
			}
		});
	}
	return true;
}


function checkIfExists(node)
{
	//Only called if portal enabled.
	var email = node.value;
	tempEmailNode = node;

	var id = ''; 
	try{
		id = document.getElementById('ID').value; //reg form has hidden ID
	} catch (e) {}
	
	var url = 'ajaxUniqueCheck.asp';
	var pars = 'tableName=Contacts' 
		     + '&fieldName=HomeEmail'
			 + '&requiresignin=false'
			 + '&bSystemWide=true'
			 + '&oid='+id
			 + '&val=' + escape(email)			 
			 + '&rnd='+ (Math.random() * Date.parse(new Date()));
			 
	var target = '';

	jQuery.ajax({
		type: 'get',
		url: url,
		data: pars,
		complete: function(r) {
			if(r.responseText.indexOf("is not a unique") > -1)
			{
				if(confirm("This email address is already in our system. Click OK to go to the portal. If you would like to change your email address, click Cancel."))
				{
					tempEmailNode.value = ""; //blank out in case they return to the reg form
					window.location.href = document.getElementById('portalLink').href + "&UserID=" + email;
				}
				else
				{
					tempEmailNode.value = "";
					tempEmailNode.focus();
				}
			}
		} 
	});
}

